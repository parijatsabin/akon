# ============================================================
# ANOK Environment Configuration
# Copy this file to .env (for migration runner) and .dev.vars
# (for Cloudflare Worker local dev). Neither file should be
# committed to git.
# ============================================================

# ── Database provider selection ──────────────────────────────
# Options: supabase | postgres | mysql
DB_PROVIDER=supabase

# ── Supabase ─────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# WARNING: service_role key bypasses RLS. Only use in the Worker
# (server-side) and the migration runner. NEVER expose in browser code.

# ── PostgreSQL (standalone — for non-Supabase deployments) ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anok
POSTGRES_USER=anok_user
POSTGRES_PASSWORD=your_secure_password_here

# ── MySQL ────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=anok
MYSQL_USER=anok_user
MYSQL_PASSWORD=your_secure_password_here

# ── WhatsApp ─────────────────────────────────────────────────
# Company WhatsApp number for guest order redirects
# Include country code, no spaces: +977XXXXXXXXXX
WHATSAPP_PHONE=+9779868765432
